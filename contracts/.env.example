# Copy to `.env` in this directory and fill in values. Never commit `.env`.
#
# Rootstock Testnet chain id: 31

# Deployer private key (hex, with or without 0x prefix). Use a dedicated testnet key only.
PRIVATE_KEY=

# Rootstock Testnet JSON-RPC URL (HTTPS)
ROOTSTOCK_TESTNET_RPC_URL=https://public-node.testnet.rsk.co

# Optional: load vars into your shell for forge
#   set -a && source .env && set +a
# Then run:
#   forge script script/DeployRootstream.s.sol:DeployRootstream --rpc-url rootstock-testnet --broadcast -vvvv
